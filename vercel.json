{
  "builds": [
    { "src": "server/app.js", "use": "@vercel/node" },
    { "src": "server/client/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/app.js" },
    { "src": "/(.*)", "dest": "/server/client/dist/$1" }
  ]
}
